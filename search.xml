        <content type="html"><![CDATA[<h1 id="WebStorm快捷键"><a href="#WebStorm快捷键" class="headerlink" title="WebStorm快捷键"></a>WebStorm快捷键</h1><div class="table-container"><table><thead><tr><th>WebStorm快捷键</th><th>说明</th></tr></thead><tbody><tr><td><code>Ctrl+Shift+U</code></td><td>大小写转换</td></tr><tr><td><code>Ctrl+D</code></td><td>复制当前行</td></tr><tr><td><code>Ctrl+F4</code></td><td>关闭当前选项卡</td></tr><tr><td><code>Ctrl+R</code></td><td>当前文件内代码替换</td></tr><tr><td><code>Ctrl+Shift+R</code></td><td>全局搜索替换</td></tr><tr><td><code>Ctrl+F</code></td><td>当前文件内搜索</td></tr><tr><td><code>Ctrl+Shift+F</code></td><td>全局搜索</td></tr><tr><td><code>Ctrl+Alt+L</code></td><td>格式化代码</td></tr><tr><td><code>Ctrl+/</code></td><td>单行注释</td></tr></tbody></table></div>]]></content>
      
      
